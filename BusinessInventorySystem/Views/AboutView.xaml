<UserControl x:Class="BusinessInventorySystem.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="660" d:DesignWidth="930">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,16">
            <TextBlock Text="About" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="Application information" Style="{StaticResource MutedText}" Margin="0,4,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" VerticalAlignment="Top" Padding="24" MaxWidth="560"
                HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock Text="&#x1F4E6; Business Inventory System" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="Version 1.0.0" Style="{StaticResource MutedText}" Margin="0,4,0,16"/>
                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                           LineHeight="20">
                    Track stock levels, record every movement, and keep a complete audit
                    history of your inventory. Use the Inventory page to manage items and
                    review each item's history, or open the Activity Log tab for a full
                    chronological record across all items.
                </TextBlock>
                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,16"/>
                <TextBlock Style="{StaticResource MutedText}">
                    Built with WPF on .NET 10 · © 2026
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
