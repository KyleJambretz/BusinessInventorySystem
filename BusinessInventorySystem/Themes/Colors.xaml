<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="#374151"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="#111827"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="SidebarTextActiveBrush" Color="#FFFFFF"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="#DBEAFE"/>

    <!-- Surfaces -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="RowAltBrush" Color="#F9FAFB"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#111827"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>

    <!-- Status -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#059669"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="#D1FAE5"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#B45309"/>
    <SolidColorBrush x:Key="WarningLightBrush" Color="#FEF3C7"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="DangerLightBrush" Color="#FEE2E2"/>
    <SolidColorBrush x:Key="NeutralBrush" Color="#4B5563"/>
    <SolidColorBrush x:Key="NeutralLightBrush" Color="#E5E7EB"/>

</ResourceDictionary>
