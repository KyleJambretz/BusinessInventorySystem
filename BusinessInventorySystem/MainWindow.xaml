<Window x:Class="BusinessInventorySystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:BusinessInventorySystem.Views"
        mc:Ignorable="d"
        Title="Business Inventory System"
        Height="700" Width="1150"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- App title -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,20">
                    <TextBlock Text="&#x1F4E6; Inventory" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource SidebarTextActiveBrush}"/>
                    <TextBlock Text="Business Inventory System" FontSize="11"
                               Foreground="{StaticResource SidebarTextBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Footer -->
                <TextBlock DockPanel.Dock="Bottom" Text="v1.0" FontSize="11"
                           Foreground="{StaticResource SidebarTextBrush}"
                           Margin="20,0,20,16"/>

                <!-- Navigation -->
                <StackPanel>
                    <RadioButton x:Name="NavInventory" Style="{StaticResource NavButton}"
                                 GroupName="Nav" Tag="&#x1F4CB;" Content="Inventory"
                                 IsChecked="True" Checked="NavInventory_Checked"/>
                    <RadioButton x:Name="NavAbout" Style="{StaticResource NavButton}"
                                 GroupName="Nav" Tag="&#x2139;" Content="About"
                                 Checked="NavAbout_Checked"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Active view -->
        <ContentControl x:Name="MainContent" Grid.Column="1"/>
    </Grid>
</Window>
